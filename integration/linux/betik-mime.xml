<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-betik">
    <comment>Betik Note File</comment>
    <comment xml:lang="tr">Betik Not Dosyası</comment>
    <glob pattern="*.tik"/>
    <magic priority="50">
      <match type="string" offset="0" value="BETIK!"/>
    </magic>
    <icon name="application-x-betik"/>
  </mime-type>
</mime-info>
